# --- IronGraph local configuration -----------------------------------------
# Copy to .env — nothing here is required for core workout tracking.

# Optional: Gemini API key for the AI coach (https://aistudio.google.com/apikey)
# Free tier is sufficient. Without it, the dashboard still works fully;
# only the "Ask IronGraph AI" features are disabled.
GEMINI_API_KEY=

# Optional: override the Gemini model (default: gemini-3.5-flash)
IRONGRAPH_GEMINI_MODEL=

# Optional: YouTube Data API key for verified technique-video search.
# Without it, IronGraph falls back to guaranteed-real YouTube search links.
YOUTUBE_API_KEY=

# Local dashboard port (default 4870)
IRONGRAPH_PORT=4870
